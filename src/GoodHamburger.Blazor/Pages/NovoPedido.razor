@page "/novo-pedido"
@page "/novo-pedido/{OrderId:guid}"
@inject GoodHamburger.Blazor.Services.IApiService Api
@inject NavigationManager Nav

<PageTitle>@(OrderId.HasValue ? "Editar Pedido" : "Novo Pedido") — Good Hamburger</PageTitle>

<div class="page-header">
    <h1>@(OrderId.HasValue ? " Editar Pedido" : " Novo Pedido")</h1>
</div>

@if (_loading)
{
    <div class="loading">Carregando...</div>
}
else
{
    <div class="order-builder">
        <div class="menu-selection">
            <h2>Selecione os itens</h2>
            <p class="hint">Máximo 1 item por categoria. Combos ganham desconto automático! 🎉</p>

            @if (_error is not null)
            {
                <div class="alert alert-error">@_error</div>
            }

            <div class="category-group">
                <h3>🥪 Sanduíches <small>(escolha 1)</small></h3>
                @foreach (var item in _menu.Where(i => i.Category == "Sandwich"))
                {
                    <label class="item-selector @(IsSelected(item.Id) ? "selected" : "")">
                        <input type="checkbox"
                               checked="@IsSelected(item.Id)"
                               @onchange="() => ToggleItem(item)" />
                        <span>@item.Name</span>
                        <span class="price">R$ @item.Price.ToString("F2")</span>
                    </label>
                }
            </div>

            <div class="category-group">
                <h3>🍟 Acompanhamentos <small>(opcional)</small></h3>
                @foreach (var item in _menu.Where(i => i.Category == "SideDish"))
                {
                    <label class="item-selector @(IsSelected(item.Id) ? "selected" : "")">
                        <input type="checkbox"
                               checked="@IsSelected(item.Id)"
                               @onchange="() => ToggleItem(item)" />
                        <span>@item.Name</span>
                        <span class="price">R$ @item.Price.ToString("F2")</span>
                    </label>
                }
            </div>

            <div class="category-group">
                <h3>🥤 Bebidas <small>(opcional)</small></h3>
                @foreach (var item in _menu.Where(i => i.Category == "Drink"))
                {
                    <label class="item-selector @(IsSelected(item.Id) ? "selected" : "")">
                        <input type="checkbox"
                               checked="@IsSelected(item.Id)"
                               @onchange="() => ToggleItem(item)" />
                        <span>@item.Name</span>
                        <span class="price">R$ @item.Price.ToString("F2")</span>
                    </label>
                }
            </div>
        </div>

        <div class="order-summary">
            <h2>Resumo do Pedido</h2>

            @if (!_selectedItems.Any())
            {
                <p class="empty-summary">Nenhum item selecionado</p>
            }
            else
            {
                <ul class="summary-items">
                    @foreach (var item in _selectedItems)
                    {
                        <li>
                            <span>@item.Name</span>
                            <span>R$ @item.Price.ToString("F2")</span>
                        </li>
                    }
                </ul>

                <div class="summary-totals">
                    <div class="subtotal-row">
                        <span>Subtotal</span>
                        <span>R$ @Subtotal.ToString("F2")</span>
                    </div>

                    @if (DiscountRate > 0)
                    {
                        <div class="discount-row">
                            <span>Desconto (@((DiscountRate * 100).ToString("F0"))%)</span>
                            <span class="discount-value">−R$ @DiscountAmount.ToString("F2")</span>
                        </div>
                    }

                    <div class="total-row">
                        <span><strong>Total</strong></span>
                        <span><strong>R$ @Total.ToString("F2")</strong></span>
                    </div>
                </div>

                @if (DiscountRate > 0)
                {
                    <div class="discount-applied">
                        🎉 Desconto de @((DiscountRate * 100).ToString("F0"))% aplicado!
                    </div>
                }
            }

            <div class="summary-actions">
                <button class="btn btn-secondary" @onclick="Cancel">Cancelar</button>
                <button class="btn btn-primary"
                        disabled="@(!_selectedItems.Any() || _saving)"
                        @onclick="SaveOrder">
                    @if (_saving)
                    {
                        <span>Salvando...</span>
                    }
                    else
                    {
                        <span>@(OrderId.HasValue ? "Atualizar" : "Confirmar Pedido")</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid? OrderId { get; set; }

    private List<GoodHamburger.Blazor.Services.MenuItemDto> _menu = new();
    private List<GoodHamburger.Blazor.Services.MenuItemDto> _selectedItems = new();
    private bool _loading = true;
    private bool _saving = false;
    private string? _error;

    // ── Computed discount preview (mirrors backend logic) ────────────────────
    private decimal Subtotal => _selectedItems.Sum(i => i.Price);

    private decimal DiscountRate
    {
        get
        {
            bool hasSandwich = _selectedItems.Any(i => i.Category == "Sandwich");
            bool hasSide     = _selectedItems.Any(i => i.Category == "SideDish");
            bool hasDrink    = _selectedItems.Any(i => i.Category == "Drink");
            return (hasSandwich, hasSide, hasDrink) switch
            {
                (true, true, true)  => 0.20m,
                (true, false, true) => 0.15m,
                (true, true, false) => 0.10m,
                _                   => 0.00m
            };
        }
    }

    private decimal DiscountAmount => Math.Round(Subtotal * DiscountRate, 2);
    private decimal Total => Subtotal - DiscountAmount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _menu = await Api.GetMenuAsync();

            if (OrderId.HasValue)
            {
                var existing = await Api.GetOrderByIdAsync(OrderId.Value);
                _selectedItems = existing.Items
                    .Select(oi => _menu.First(m => m.Id == oi.MenuItemId))
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            _error = $"Erro: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private bool IsSelected(int id) => _selectedItems.Any(i => i.Id == id);

    private void ToggleItem(GoodHamburger.Blazor.Services.MenuItemDto item)
    {
        _error = null;
        if (IsSelected(item.Id))
        {
            _selectedItems.RemoveAll(i => i.Id == item.Id);
        }
        else
        {
            // Validação prévia no frontend
            if (_selectedItems.Any(i => i.Category == item.Category))
            {
                _error = $"Já existe um item da categoria '{CategoryLabel(item.Category)}' selecionado.";
                return;
            }
            _selectedItems.Add(item);
        }
    }

    private async Task SaveOrder()
    {
        _saving = true;
        _error = null;
        try
        {
            var ids = _selectedItems.Select(i => i.Id).ToList();
            if (OrderId.HasValue)
                await Api.UpdateOrderAsync(OrderId.Value, ids);
            else
                await Api.CreateOrderAsync(ids);

            Nav.NavigateTo("/pedidos");
        }
        catch (Exception ex)
        {
            _error = $"Erro ao salvar pedido: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => Nav.NavigateTo("/pedidos");

    private static string CategoryLabel(string cat) => cat switch
    {
        "Sandwich" => "Sanduíche",
        "SideDish" => "Acompanhamento",
        "Drink"    => "Bebida",
        _          => cat
    };
}
