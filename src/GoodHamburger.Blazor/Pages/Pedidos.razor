@page "/pedidos"
@inject GoodHamburger.Blazor.Services.IApiService Api
@inject NavigationManager Nav

<PageTitle>Pedidos — Good Hamburger</PageTitle>

<div class="page-header">
    <h1>Pedidos</h1>
   <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/novo-pedido")'>
        ➕ Novo Pedido
    </button>
</div>

@if (_loading)
{
    <div class="loading">Carregando pedidos...</div>
}
else if (_error is not null)
{
    <div class="alert alert-error">@_error</div>
}
else if (!_orders.Any())
{
    <div class="empty-state">
        <p>Nenhum pedido encontrado.</p>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/novo-pedido")'>
            Criar primeiro pedido
        </button>
    </div>
}
else
{
    <div class="orders-list">
        @foreach (var order in _orders)
        {
            <div class="order-card">
                <div class="order-header">
                    <span class="order-id">Pedido #@order.Id.ToString()[..8].ToUpper()</span>
                    <span class="order-status status-@order.Status.ToLower()">@order.Status</span>
                    <span class="order-date">@order.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</span>
                </div>

                <div class="order-items">
                    @foreach (var item in order.Items)
                    {
                        <span class="order-item-tag">@item.Name</span>
                    }
                </div>

                <div class="order-totals">
                    <span>Subtotal: <strong>R$ @order.Subtotal.ToString("F2")</strong></span>
                    @if (order.DiscountRate > 0)
                    {
                        <span class="discount-badge">-@((order.DiscountRate * 100).ToString("F0"))% (−R$ @order.DiscountAmount.ToString("F2"))</span>
                    }
                    <span class="total-final">Total: <strong>R$ @order.Total.ToString("F2")</strong></span>
                </div>

                <div class="order-actions">
                    <button class="btn btn-secondary btn-sm"
                            @onclick="() => EditOrder(order.Id)">
                        ✏️ Editar
                    </button>
                    <button class="btn btn-danger btn-sm"
                            @onclick="() => DeleteOrder(order.Id)">
                        🗑️ Excluir
                    </button>
                </div>
            </div>
        }
    </div>
}

@if (_successMsg is not null)
{
    <div class="alert alert-success">@_successMsg</div>
}

@code {
    private List<GoodHamburger.Blazor.Services.OrderDto> _orders = new();
    private bool _loading = true;
    private string? _error;
    private string? _successMsg;

    protected override async Task OnInitializedAsync() => await LoadOrders();

    private async Task LoadOrders()
    {
        _loading = true;
        _error = null;
        try
        {
            _orders = await Api.GetOrdersAsync();
        }
        catch (Exception ex)
        {
            _error = $"Erro ao carregar pedidos: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void EditOrder(Guid id) => Nav.NavigateTo($"/novo-pedido/{id}");

    private async Task DeleteOrder(Guid id)
    {
        try
        {
            await Api.DeleteOrderAsync(id);
            _successMsg = "Pedido excluído com sucesso!";
            await LoadOrders();
            await Task.Delay(3000);
            _successMsg = null;
        }
        catch (Exception ex)
        {
            _error = $"Erro ao excluir pedido: {ex.Message}";
        }
    }
}
