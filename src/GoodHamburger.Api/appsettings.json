{
  "Kestrel": {
    "AddServerHeader": false,
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5001",
      "https://localhost:5001"
    ]
  },
  "Security": {
    "ApiKey": {
      "ApiKey": "goodhamburger-local-dev-key"
    }
  }
}
